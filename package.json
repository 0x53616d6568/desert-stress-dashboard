{
  "name": "desert-stress-monitor",
  "version": "1.0.0",
  "description": "Desert Stress Monitor - Full-stack React + Express + PostgreSQL application",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cd server && npm run dev",
    "client:dev": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "setup": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "keywords": [
    "desert",
    "stress-monitor",
    "lora",
    "telemetry",
    "react",
    "express",
    "postgresql"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
